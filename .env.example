# Synology NAS
SYNOLOGY_HOST=192.168.1.10
# Photos portal alias (Control Panel → Login Portal → Applications). Use empty if you
# open Photos via DSM (?launchApp=SYNO.Foto…) and /photo/webapi returns HTTP 403:
# SYNOLOGY_PHOTOS_ALIAS=
SYNOLOGY_PHOTOS_ALIAS=photo
SYNOLOGY_VERIFY_SSL=false
SYNOLOGY_USERNAME=your_user
SYNOLOGY_PASSWORD=your_password
# personal = SYNO.Foto.* (Photos tab) | shared = SYNO.FotoTeam.* (Shared Space)
# Service accounts usually need SYNOLOGY_SPACE=shared — see README "DSM service account"
SYNOLOGY_SPACE=shared
SYNOLOGY_THUMBNAIL_SIZE=sm
# Resize before Ollama (longest edge px; 0 = disable)
VISION_MAX_EDGE=512

# OpenAI-compatible vision API (any /v1/chat/completions endpoint — see README)
# Recommended: local Ollama — private photos stay on your network (see README Privacy section)
OPENAI_API_BASE=http://192.168.1.50:11434/v1
OPENAI_API_KEY=ollama
# Recommended: gemma3 (see README reference run). Alternatives: llava-llama3, bakllava
OPENAI_MODEL=gemma3
OPENAI_MAX_TOKENS=256
# Sampling (Ollama options + OpenAI seed when supported). Omit OPENAI_SEED for random.
OPENAI_TEMPERATURE=0.1
# OPENAI_SEED=42
#
# OpenAI cloud (leave OPENAI_API_BASE empty, or set https://api.openai.com/v1):
# OPENAI_API_KEY=sk-...
# OPENAI_API_BASE=
# OPENAI_MODEL=gpt-4o-mini
#
# Google Gemma 3 vision via Ollama (often reliable JSON on first call — see README reference run):
# OPENAI_MODEL=gemma3
#
# Google Gemini (OpenAI-compatible — thumbnails sent to Google):
# OPENAI_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai/
# OPENAI_API_KEY=your-gemini-api-key
# OPENAI_MODEL=gemini-2.0-flash
#
# Open WebUI — OpenAI-compatible Ollama proxy at /ollama/v1:
# OPENAI_API_BASE=http://192.168.1.60:8080/ollama/v1
# OPENAI_API_KEY=your-open-webui-api-key
# OPENAI_MODEL=llava-llama3
#
# If Ollama runs on the same machine as Docker Desktop (Mac/Windows):
# OPENAI_API_BASE=http://host.docker.internal:11434/v1

# Tagging behavior
TAG_PREFIX=ai
MAX_TAGS=12
SKIP_IF_TAGGED=true
WRITE_DESCRIPTION=true
# Reuse JPEG analysis for RAW/NEF with the same basename (one vision call per scene)
REUSE_JPEG_ANALYSIS_FOR_RAW=true
# Pass Synology reverse-geocoded city/country (EXIF GPS) into the vision prompt (default off)
# USE_LOCATION_IN_PROMPT=true
# Concurrent vision API calls (default 1). NAS writes stay sequential. Cloud: try 2–4.
# PROCESS_PARALLEL=2

# Watcher (synology-photos-ai watch)
WATCH_INTERVAL_SECONDS=300

# Docker: persisted SQLite state (default in container is /data/processed.db)
# STATE_PATH=/data/processed.db
#
# When running the container ON the Synology NAS, use the NAS LAN IP for SYNOLOGY_HOST
# (not localhost). Ollama still points at your external GPU machine.
